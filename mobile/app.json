{
  "expo": {
    "name": "Sionnach",
    "slug": "sionnach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "sionnach",
    "splash": {
      "backgroundColor": "#0d1a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sionnach.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sionnach needs microphone access to identify Irish tunes being played nearby."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d1a0f"
      },
      "package": "com.sionnach.app",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Sionnach needs microphone access to identify Irish tunes being played nearby."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          }
        }
      ],
      "./plugins/withOnnxruntimeFix"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a833463d-be46-4f8e-be5e-bef5af9ac889"
      }
    },
    "owner": "msolters"
  }
}
